{
  "manifest_version": 3,
  "name": "WeRead Eye Care",
  "version": "0.1.0",
  "description": "Active-reading TTS reminders for WeRead.",
  "permissions": ["storage"],
  "host_permissions": ["https://weread.qq.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/main.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://weread.qq.com/web/reader/*"],
      "js": ["content/main.js"]
    }
  ],
  "action": {
    "default_title": "WeRead Eye Care",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html"
}
